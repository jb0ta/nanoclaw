# Dependencies
node_modules/
.npm-cache/
# pnpm content-addressable store (created when running in sandbox mode)
.pnpm-store/
# Build output
dist/

# Local data & auth
store/
logs/

# data/ — ignore runtime artifacts, track agent-group session config
data/v2.db
data/v2.db-shm
data/v2.db-wal
data/v2-sessions/
data/env/
data/ipc/
data/cli.sock
data/telegram-pairings.json

# Groups — ignore runtime state, track CLAUDE.md and container config
groups/*/CLAUDE.local.md
groups/*/memory/
groups/*/.claude/
groups/*/agent-runner-src/
# track: groups/*/CLAUDE.md  groups/*/container.json  groups/*/skills/

# Composer-managed CLAUDE.md artifacts (regenerated every spawn) and
# per-group memory (CLAUDE.local.md) must never be committed.
**/CLAUDE.local.md
**/.claude-shared.md
**/.claude-fragments/

# Secrets
*.keys.json
.env
.env*

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Skills system (local per-installation state)
.nanoclaw/

agents-sdk-docs
